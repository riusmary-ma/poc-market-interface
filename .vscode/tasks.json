{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build backend",
      "type": "shell",
      "command": "dotnet",
      "args": ["build", "${workspaceFolder}/PocMarketInterface.csproj"],
      "group": {"kind": "build", "isDefault": true},
      "problemMatcher": ["$msCompile"],
      "presentation": {"reveal": "always", "panel": "shared"}
    },
    {
      "label": "run backend",
      "type": "shell",
      "command": "dotnet",
      "args": ["run", "--project", "${workspaceFolder}/PocMarketInterface.csproj", "--urls", "http://localhost:5000"],
      "isBackground": true,
      "problemMatcher": ["$msCompile"],
      "presentation": {"reveal": "always", "panel": "dedicated"}
    },
    {
      "label": "start frontend",
      "type": "shell",
      "command": "npm",
      "args": ["start"],
      "isBackground": true,
      "presentation": {"reveal": "always", "panel": "dedicated"}
    }
  ]
}
